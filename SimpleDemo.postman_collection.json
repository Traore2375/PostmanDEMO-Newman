{
  "info": {
    "_postman_id": "91426adb-d881-48e3-b9f3-4dc54f3c11f3",
    "name": "SimpleDemo_CLEAN",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt}}",
        "type": "string"
      }
    ]
  },

  "variable": [
    { "key": "projectId", "value": "14" },
    { "key": "requirementId", "value": "" },
    { "key": "testCaseId", "value": "" },
    { "key": "reqName", "value": "" },
    { "key": "testCaseName", "value": "" }
  ],

  "item": [
    {
      "name": "GET Projects",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{url}}/projects?size=50&page=0",
          "host": ["{{url}}"],
          "path": ["projects"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Response valid', () => {",
              "  pm.expect(json).to.not.be.null;",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "POST Create Requirement",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{url}}/requirements",
          "host": ["{{url}}"],
          "path": ["requirements"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"_type\": \"requirement\",\n  \"parent\": {\n    \"_type\": \"requirement-folder\",\n    \"id\": 6440\n  },\n  \"current_version\": {\n    \"name\": \"{{reqName}}\",\n    \"criticality\": \"MINOR\",\n    \"status\": \"WORK_IN_PROGRESS\",\n    \"description\": \"Auto generated requirement\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('reqName', 'REQ_' + Date.now() + '_' + Math.floor(Math.random()*1000));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Requirement created', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.expect(json.id).to.exist;",
              "pm.collectionVariables.set('requirementId', json.id);"
            ]
          }
        }
      ]
    },

    {
      "name": "POST Create Test Case",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{url}}/test-cases",
          "host": ["{{url}}"],
          "path": ["test-cases"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"_type\": \"test-case\",\n  \"name\": \"{{testCaseName}}\",\n  \"parent\": {\n    \"_type\": \"project\",\n    \"id\": {{projectId}}\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('testCaseName', 'TC_' + Date.now() + '_' + Math.floor(Math.random()*1000));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Test case created', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.expect(json.id).to.exist;",
              "pm.collectionVariables.set('testCaseId', json.id);"
            ]
          }
        }
      ]
    },

    {
      "name": "PATCH Requirement",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{url}}/requirements/{{requirementId}}",
          "host": ["{{url}}"],
          "path": ["requirements", "{{requirementId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"_type\": \"requirement\",\n  \"current_version\": {\n    \"name\": \"UPDATED_{{reqName}}\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Requirement updated', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "if (json && json.current_version) {",
              "  pm.expect(json.current_version.name).to.include('UPDATED_');",
              "}"
            ]
          }
        }
      ]
    }
  ]
}